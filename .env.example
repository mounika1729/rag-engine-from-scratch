# ─────────────────────────────────────────────
#  RAG From Scratch — Environment Configuration
# ─────────────────────────────────────────────
# LLM Provider (choose one)
GROQ_API_KEY=your_key_here
LLM_MODEL=llama-3.1-8b-instant
#or 
OPENAI_API_KEY=sk-...


# LLM Settings
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# Embedding Settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_MODEL=text-embedding-3-small   # OpenAI option

# Vector Store Settings
VECTOR_STORE_TYPE=faiss        # Options: faiss | chroma
VECTOR_STORE_PATH=./data/vectorstore
CHROMA_COLLECTION_NAME=rag_collection

# Chunking Settings
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNKING_STRATEGY=recursive    # Options: recursive | sentence | semantic

# Retrieval Settings
TOP_K=5
RETRIEVAL_MODE=hybrid          # Options: dense | sparse | hybrid
RERANK_RESULTS=true
RERANK_TOP_N=3

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/rag.log

